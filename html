setInterval(function(){
  rot.style.transition='opacity .35s';
  rot.style.opacity=0;
  setTimeout(function(){ wi=(wi+1)%words.length; rot.textContent=words[wi]; rot.style.opacity=1; },380);
},3200);

/* Statement: word-by-word light-up on scroll */
