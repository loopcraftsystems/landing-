var CONSENT_COOKIE='lc_consent';
function getConsent(){
  var m=document.cookie.match(new RegExp('(?:^|; )'+CONSENT_COOKIE+'=([^;]*)'));
  return m?m[1]:null;
}
function setConsent(v){
  document.cookie=CONSENT_COOKIE+'='+v+'; max-age=15552000; path=/; SameSite=Lax';
