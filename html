function buildMarquee(){
  var t=document.getElementById('marquee-track');
  var base=t.dataset.base||(t.dataset.base=t.innerHTML);
  var half=base;
  t.innerHTML=half;
  var guard=0;
  while(t.scrollWidth < window.innerWidth*1.2 && guard++ < 40){ half+=base; t.innerHTML=half; }
  half+=base; // extra set so the seam is always off-screen
  t.innerHTML=half+half;
}
buildMarquee();
var rt; window.addEventListener('resize',function(){ clearTimeout(rt); rt=setTimeout(buildMarquee,200); },{passive:true});

