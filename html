<style>
/* ================================================================
   LOOPCRAFT V4 : ANIMATED MONOCHROME GALLERY
   Brand-led. No badges, no prices, no procurement language.
   NO colored accents, ever.
   ================================================================ */
:root{
  --bg:#0a0a0a; --ink:#fafafa; --muted:#a3a3a3; --faint:#5c5c5c;
  --hair:#262626; --maxw:1280px;
  --ease:cubic-bezier(.22,1,.36,1);
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth;scroll-padding-top:88px}
body{
  background:var(--bg);color:var(--ink);
  font-family:'Inter',system-ui,sans-serif;font-size:16px;line-height:1.6;
  -webkit-font-smoothing:antialiased;overflow-x:hidden;
}
::selection{background:var(--ink);color:var(--bg)}
a{color:var(--ink);text-decoration:none}
:focus-visible{outline:2px solid var(--ink);outline-offset:3px;border-radius:2px}
h1,h2,h3{font-family:'Space Grotesk',sans-serif;font-weight:400;letter-spacing:-0.02em}
.wrap{max-width:var(--maxw);margin:0 auto;padding:0 24px}
@media(min-width:768px){.wrap{padding:0 56px}}

/* ---------- nav ---------- */
nav{position:fixed;top:0;left:0;right:0;z-index:90;mix-blend-mode:difference}
nav .wrap{display:flex;justify-content:space-between;align-items:center;height:76px}
.logo{font-family:'Space Grotesk';letter-spacing:.16em;font-size:15px;font-weight:500;display:flex;align-items:center;gap:12px}
.nav-links{display:flex;gap:32px;align-items:center}
.nav-links a{font-size:13px;color:var(--ink);opacity:.65;transition:opacity .25s;position:relative}
.nav-links a::after{
  content:"";position:absolute;left:0;bottom:-4px;height:1px;width:0;
  background:var(--ink);transition:width .35s var(--ease);
}
.nav-links a:hover{opacity:1}
.nav-links a:hover::after{width:100%}
.menu-btn{display:none;background:none;border:0;color:var(--ink);font-size:24px;line-height:1;cursor:pointer;padding:4px 6px}
@media(max-width:860px){
  .menu-btn{display:block}
  .nav-links{
    position:fixed;top:76px;left:0;right:0;
    background:var(--bg);mix-blend-mode:normal;
    flex-direction:column;align-items:flex-start;gap:0;
    border-bottom:1px solid var(--hair);
    padding:8px 24px 20px;
    transform:translateY(-12px);opacity:0;pointer-events:none;
    transition:opacity .3s var(--ease),transform .3s var(--ease);
  }
  .nav-links.open{transform:none;opacity:1;pointer-events:auto}
  .nav-links a{font-size:15px;opacity:.85;padding:14px 0;width:100%;border-bottom:1px solid var(--hair)}
  .nav-links a:last-child{border-bottom:0}
}

/* ---------- hero ---------- */
.hero{min-height:100svh;display:flex;flex-direction:column;justify-content:center;position:relative;overflow:hidden}
.hero-grid{
  position:absolute;inset:0;pointer-events:none;opacity:.35;
  background:
    linear-gradient(var(--hair) 1px,transparent 1px),
    linear-gradient(90deg,var(--hair) 1px,transparent 1px);
  background-size:120px 120px;
  animation:griddrift 60s linear infinite;
}
@keyframes griddrift{to{background-position:120px 120px}}
.hero .eyebrow{font-size:11px;letter-spacing:.22em;text-transform:uppercase;color:var(--muted);margin-bottom:36px}
.hero h1{font-size:clamp(44px,9vw,120px);line-height:.98;letter-spacing:-0.035em;max-width:12ch}
.hero h1 .line{display:block;overflow:hidden}
.hero h1 .line span{display:block;transform:translateY(110%);animation:riseup 1.1s var(--ease) forwards}
.hero h1 .line:nth-child(2) span{animation-delay:.12s}
.hero h1 .line:nth-child(3) span{animation-delay:.24s}
@keyframes riseup{to{transform:none}}
.hero .rotator{display:inline-block;min-width:6.5ch;color:var(--muted);font-style:normal}
.hero .sub{
  margin-top:44px;font-size:clamp(15px,1.6vw,19px);color:var(--muted);
  max-width:46ch;opacity:0;animation:fadein 1s .7s var(--ease) forwards;
}
@keyframes fadein{to{opacity:1}}
.hero .cta-row{margin-top:44px;display:flex;gap:20px;align-items:center;flex-wrap:wrap;opacity:0;animation:fadein 1s .9s var(--ease) forwards}
.btn{
  display:inline-block;background:var(--ink);color:var(--bg);
  font-size:14px;font-weight:500;padding:16px 38px;border:1px solid var(--ink);
  border-radius:999px;font-family:inherit;
  transition:background .25s,color .25s;cursor:pointer;
}
.btn:hover{background:transparent;color:var(--ink)}
.btn-ghost{
  display:inline-block;font-size:14px;font-weight:500;padding:16px 30px;
  border:1px solid var(--hair);border-radius:999px;color:var(--ink);
  transition:border-color .25s;
}
.btn-ghost:hover{border-color:var(--ink)}
.hero .scroll-hint{
  position:absolute;bottom:32px;left:50%;transform:translateX(-50%);
  font-size:10px;letter-spacing:.3em;text-transform:uppercase;color:var(--faint);
  animation:bob 2.4s ease-in-out infinite;
}
@keyframes bob{50%{transform:translate(-50%,8px)}}

/* ---------- marquee : verbs, not badges ---------- */
.marquee{
  border-top:1px solid var(--hair);border-bottom:1px solid var(--hair);
  overflow:hidden;padding:22px 0;white-space:nowrap;
}
.marquee-track{display:inline-block;animation:scroll 28s linear infinite}
.marquee:hover .marquee-track{animation-play-state:paused}
.marquee span{
  font-family:'Space Grotesk';font-size:14px;letter-spacing:.14em;
  text-transform:uppercase;color:var(--muted);padding:0 32px;
}
.marquee em{font-style:normal;color:var(--faint);padding:0 4px}
@keyframes scroll{to{transform:translateX(-50%)}}

/* ---------- sections ---------- */
section{padding:140px 0}
@media(max-width:767px){section{padding:88px 0}}
.chapter{font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:var(--faint);display:block;margin-bottom:28px}
.sec-head{font-size:clamp(26px,4.2vw,48px);line-height:1.1;max-width:22ch;margin-bottom:20px}
.sec-lead{font-size:15px;color:var(--muted);max-width:56ch}

/* ---------- statement ---------- */
.statement h2{font-size:clamp(26px,4.2vw,54px);line-height:1.18;max-width:26ch}
.statement h2 .w{display:inline-block;opacity:.12;transition:opacity .6s var(--ease)}
.statement h2 .w.lit{opacity:1}
.statement .after{margin-top:48px;font-size:15px;color:var(--muted);max-width:52ch}

/* ---------- principle grid (philosophy) ---------- */
.grid4{display:grid;gap:1px;background:var(--hair);border:1px solid var(--hair);margin-top:56px}
@media(min-width:640px){.grid4{grid-template-columns:repeat(2,1fr)}}
@media(min-width:960px){.grid4{grid-template-columns:repeat(4,1fr)}}
.cell{background:var(--bg);padding:36px 30px;transition:background .35s}
.cell:hover{background:#111}
.cell .num{font-family:'Space Grotesk';font-size:12px;letter-spacing:.2em;color:var(--faint);display:block;margin-bottom:22px}
.cell h3{font-size:20px;margin-bottom:12px}
.cell p{font-size:13.5px;color:var(--muted)}

/* ---------- methodology (LOOP) ---------- */
.phase{
  display:grid;grid-template-columns:96px 1fr;gap:32px;
  border-top:1px solid var(--hair);padding:44px 0;
}
.phase:last-child{border-bottom:1px solid var(--hair)}
.phase .glyph{
  font-family:'Space Grotesk';font-weight:300;font-size:clamp(40px,6vw,72px);
  line-height:1;color:transparent;-webkit-text-stroke:1px var(--faint);
  transition:-webkit-text-stroke-color .4s;
}
.phase:hover .glyph{-webkit-text-stroke-color:var(--ink)}
.phase h3{font-size:clamp(19px,2.4vw,26px);margin-bottom:6px}
.phase h3 small{display:block;font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:var(--faint);font-weight:400;margin-top:8px;font-family:'Inter'}
.phase p{font-size:14px;color:var(--muted);max-width:70ch;margin-top:14px}
@media(max-width:600px){.phase{grid-template-columns:1fr;gap:14px}}

/* ---------- services ---------- */
.svc-row{border-top:1px solid var(--hair)}
.svc{
  border-bottom:1px solid var(--hair);
  display:grid;grid-template-columns:64px 1fr auto;align-items:center;gap:24px;
  padding:44px 0;cursor:pointer;position:relative;
  transition:padding-left .4s var(--ease);
}
@media(min-width:768px){.svc:hover{padding-left:24px}}
.svc .idx{font-family:'Space Grotesk';font-size:13px;color:var(--faint)}
.svc h3{font-size:clamp(22px,3.4vw,40px);letter-spacing:-0.02em}
.svc .hint{font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:var(--faint);white-space:nowrap}
.svc .desc{
  grid-column:2/4;font-size:14px;color:var(--muted);max-width:64ch;
  max-height:0;overflow:hidden;transition:max-height .5s var(--ease),margin .5s var(--ease);
}
.svc:hover .desc,.svc:focus-within .desc{max-height:320px;margin-top:14px}
.svc .desc ul{list-style:none;margin-top:14px}
.svc .desc li{padding:8px 0;border-top:1px solid var(--hair);font-size:13.5px;color:var(--muted)}
.svc .desc li::before{content:"→ ";color:var(--ink)}
@media(max-width:767px){.svc .desc{max-height:none;margin-top:8px}}
.svc .arrow{
  position:absolute;right:0;top:44px;font-size:22px;color:var(--faint);
  transition:transform .4s var(--ease),color .3s;
}
.svc:hover .arrow{transform:translateX(8px);color:var(--ink)}

/* ---------- benefits pills ---------- */
.pills{display:flex;flex-wrap:wrap;gap:12px;margin-top:48px}
.pill{
  border:1px solid var(--hair);border-radius:999px;padding:8px 18px;
  font-size:12.5px;color:var(--muted);transition:border-color .3s,color .3s;
}
.pill:hover{border-color:var(--faint);color:var(--ink)}
.pill strong{color:var(--ink);font-weight:500;margin-right:8px}

/* ---------- approach : inverse band ---------- */
.approach{background:var(--ink);color:var(--bg);padding:120px 0}
.approach .chapter{color:#8a8a8a}
.approach h2{font-size:clamp(26px,4vw,52px);max-width:20ch;line-height:1.2}
.approach h2 em{font-style:normal;color:#9a9a9a}

/* ---------- work ---------- */
.eng-note{
  font-size:13px;color:var(--muted);border:1px solid var(--hair);
  border-left:2px solid var(--ink);padding:14px 20px;margin-bottom:32px;max-width:760px;
}
.work-grid{display:grid;gap:1px;background:var(--hair);border:1px solid var(--hair)}
@media(min-width:768px){.work-grid{grid-template-columns:repeat(3,1fr)}}
.work{
  background:var(--bg);padding:44px 32px;position:relative;overflow:hidden;
}
.work::before{
  content:"";position:absolute;inset:0;background:var(--ink);
  transform:translateY(101%);transition:transform .45s var(--ease);
}
.work:hover::before{transform:none}
.work>*{position:relative;z-index:1;transition:color .35s}
.work .sector{font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:var(--faint)}
.work .rep{font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--faint);border:1px solid var(--hair);padding:3px 9px;border-radius:999px;display:inline-block;margin:14px 0}
.work h3{font-size:19px;line-height:1.3;margin-bottom:10px}
.work p{font-size:13.5px;color:var(--muted)}
.work .outcome{margin-top:16px;padding-top:14px;border-top:1px solid var(--hair);font-size:13px;color:var(--muted)}
.work .outcome strong{color:var(--ink);display:block;margin-bottom:4px;font-weight:500}
.work:hover .sector,.work:hover .rep,.work:hover p,.work:hover .outcome{color:#3d3d3d}
.work:hover h3,.work:hover .outcome strong{color:var(--bg)}
.work:hover .rep{border-color:#c9c9c9}
.work:hover .outcome{border-color:#c9c9c9}

/* ---------- contact ---------- */
.contact{text-align:center;padding:160px 0}
.contact h2{font-size:clamp(34px,6vw,84px);letter-spacing:-0.03em;line-height:1.02;margin-bottom:24px}
.contact p{color:var(--muted);max-width:48ch;margin:0 auto 40px;font-size:15px}
.contact .email{
  font-family:'Space Grotesk';font-size:clamp(17px,2.4vw,26px);
  border-bottom:1px solid var(--hair);padding-bottom:5px;transition:border-color .3s;
}
.contact .email:hover{border-color:var(--ink)}
/* form */
.c-form{max-width:560px;margin:56px auto 0;text-align:left}
.field{margin-bottom:22px}
.field label{display:block;font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--faint);margin-bottom:10px}
.field input,.field textarea{
  width:100%;background:transparent;border:0;border-bottom:1px solid var(--hair);
  color:var(--ink);font-family:inherit;font-size:16px;padding:12px 2px;transition:border-color .3s;
}
.field input:focus,.field textarea:focus{outline:none;border-color:var(--ink)}
.field textarea{min-height:120px;resize:vertical}
.c-form .btn{width:100%;margin-top:8px}
.form-note{margin-top:18px;font-size:12px;color:var(--faint);text-align:center}
.contact .note{margin-top:40px;font-size:12px;color:var(--faint)}

/* ---------- footer ---------- */
footer{border-top:1px solid var(--hair);overflow:hidden}
.giant{white-space:nowrap;padding:48px 0 32px}
.giant-track{display:inline-block;animation:scroll 40s linear infinite}
.giant span{
  font-family:'Space Grotesk';font-size:clamp(72px,14vw,180px);
  letter-spacing:-0.02em;padding:0 40px;
  color:transparent;-webkit-text-stroke:1px var(--hair);
  transition:-webkit-text-stroke-color .4s;
}
.giant:hover span{-webkit-text-stroke-color:var(--faint)}
.foot-row{
  border-top:1px solid var(--hair);
  display:flex;flex-wrap:wrap;gap:20px;justify-content:space-between;align-items:center;
  padding:28px 0;
}
.foot-row a,.foot-row span{font-size:12px;color:var(--faint)}
.foot-row a:hover{color:var(--ink)}
.foot-links{display:flex;gap:24px;flex-wrap:wrap}
.entity{border-top:1px solid var(--hair)}
.entity .wrap{padding-top:24px;padding-bottom:36px;font-size:12px;color:var(--faint);line-height:1.9}
.entity strong{color:var(--muted);font-weight:500}

/* ---------- consent banner ---------- */
#consent{
  position:fixed;bottom:0;left:0;right:0;z-index:100;
  background:#111;border-top:1px solid var(--hair);padding:18px 0;display:none;
}
#consent.show{display:block}
#consent .wrap{display:flex;align-items:center;justify-content:space-between;gap:20px;flex-wrap:wrap}
#consent p{font-size:12.5px;color:var(--muted);max-width:680px}
#consent .actions{display:flex;gap:10px}
#consent button{
  font-family:inherit;font-size:13px;font-weight:500;padding:10px 22px;
  border-radius:999px;cursor:pointer;
}
#consent .accept{background:var(--ink);color:var(--bg);border:1px solid var(--ink)}
#consent .decline{background:transparent;color:var(--muted);border:1px solid var(--hair)}

/* ---------- reveal ---------- */
.reveal{opacity:0;transform:translateY(28px);transition:opacity .9s var(--ease),transform .9s var(--ease)}
.reveal.visible{opacity:1;transform:none}
@media(prefers-reduced-motion:reduce){
  *,*::before,*::after{animation:none!important;transition:none!important}
  html{scroll-behavior:auto}
  .reveal,.hero h1 .line span,.hero .sub,.hero .cta-row{opacity:1;transform:none}
  .statement h2 .w{opacity:1}
}
</style>
